<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Atividade 14</title>

<style>
    #personagem {
        width: 50px;
        height: 50px;
        background-color: blue;
        position: absolute;
        top: 100px;
        left: 100px;
    }
</style>
</head>
<body>

<div id="personagem"></div>

<button id="ativar">Ativar Movimento</button>
<button id="desativar">Desativar Movimento</button>

<script>
    const personagem = document.getElementById("personagem");
    const btnAtivar = document.getElementById("ativar");
    const btnDesativar = document.getElementById("desativar");

    let x = 100;
    let y = 100;

    function mover(evento) {
        if (evento.key === "ArrowUp") {
            y -= 10;
        } else if (evento.key === "ArrowDown") {
            y += 10;
        } else if (evento.key === "ArrowLeft") {
            x -= 10;
        } else if (evento.key === "ArrowRight") {
            x += 10;
        }

        personagem.style.left = x + "px";
        personagem.style.top = y + "px";
    }

    btnAtivar.addEventListener("click", function() {
        document.addEventListener("keydown", mover);
    });

    btnDesativar.addEventListener("click", function() {
        document.removeEventListener("keydown", mover);
    });
</script>

</body>
</html>
