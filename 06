<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atividade 6</title>
</head>

<body>

    <button id="btnAtivar">Ativar Cor</button>
    <button id="btnDesativar">Desativar Cor</button>


    <div id="meuRetangulo"
        style="width: 300px; height: 100px; background-color: tomato; margin-top: 20px; border-radius: 8px; transition: background-color 0.3s; cursor: pointer;">
    </div>

    <p id="mensagemStatus">Status: Evento desativado</p>


    <script>
        
        const btnAtivar = document.getElementById('btnAtivar');
        const btnDesativar = document.getElementById('btnDesativar');
        const retangulo = document.getElementById('meuRetangulo');
        const mensagemStatus = document.getElementById('mensagemStatus');

       
        function mudarParaAzul() {
            retangulo.style.backgroundColor = 'blue';
        }

       
        btnAtivar.addEventListener('click', function () {
            // Remove o evento antes para evitar duplicações na memória
            retangulo.removeEventListener('click', mudarParaAzul);

            retangulo.addEventListener('click', mudarParaAzul);
            mensagemStatus.textContent = 'Status: Evento ATIVO! Clique no retângulo.';
        });

       
        btnDesativar.addEventListener('click', function () {
            retangulo.removeEventListener('click', mudarParaAzul);
            mensagemStatus.textContent = 'Status: Evento desativado.';

           
            retangulo.style.backgroundColor = 'tomato';
        });


    </script>

</body>

</html>
